clt_bill = AcsClient(ACCESS_KEY_ID, ACCESS_KEY_SECRET, BILL_REG_ID)

# =========================
# 通用函数
# =========================
def send_tg(chat_id, text, parse_mode=None):
    try:
        data = {
            'chat_id': chat_id,
            'text': text
        }
        if parse_mode:
            data['parse_mode'] = parse_mode
        res = requests.post(
            f'https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}/sendMessage',
            data=data,
            timeout=10
        )
        if not res.ok:
            logging.error(f'TG发送失败: {res.text}')
            return False
        return True
    except Exception as e:
        logging.error(f'发送TG失败: {str(e)}')
        return False


def is_admin(update: Update):
    user_id = update.effective_user.id if update.effective_user else None
    return str(user_id) == str(ADMIN_USER_ID)


def get_chat_id(update: Update):
    return update.effective_chat.id if update.effective_chat else ADMIN_USER_ID


def keepalive_enabled():
    return os.path.exists(KEEPALIVE_FLAG_FILE)


def set_keepalive_enabled(enabled: bool):
    if enabled:
        with open(KEEPALIVE_FLAG_FILE, 'w') as f:
            f.write('enabled\n')
    else:
        if os.path.exists(KEEPALIVE_FLAG_FILE):
            os.remove(KEEPALIVE_FLAG_FILE)


def load_notify_state():
    try:
        if not os.path.exists(LAST_NOTIFY_FILE):
            return {}
        with open(LAST_NOTIFY_FILE, 'r') as f:
            return json.load(f)
    except Exception:
        return {}


def save_notify_state(state):
    try:
        with open(LAST_NOTIFY_FILE, 'w') as f:
            json.dump(state, f, ensure_ascii=False, indent=2)
    except Exception as e:
        logging.error(f'保存通知状态失败: {str(e)}')


def notify_once(key, text):
    state = load_notify_state()
    if state.get(key):
        return False
    if send_tg(TELEGRAM_CHAT_ID, text):
        state[key] = now_text()
        save_notify_state(state)
        return True
    return False


def clear_notify_key(key):
    state = load_notify_state()
    if key in state:
        del state[key]
        save_notify_state(state)


def has_notify_key(key):
    return bool(load_notify_state().get(key))


def set_pending_keepalive(status):
    state = load_notify_state()
    state['keepalive_pending'] = {
        'time': now_text(),
        'status': status
    }
    save_notify_state(state)


def get_pending_keepalive():
    state = load_notify_state()
    return state.get('keepalive_pending')


def clear_pending_keepalive():
    state = load_notify_state()
    if 'keepalive_pending' in state:
        del state['keepalive_pending']
        save_notify_state(state)

# =========================
# ECS 状态与控制
# =========================
def get_vps_status():
    if not INSTANCE_ID or '你的' in INSTANCE_ID:
        return 'Unknown'
    try:
        request = DescribeInstancesRequest.DescribeInstancesRequest()
        request.set_InstanceIds([INSTANCE_ID])
        response = clt_ecs.do_action_with_exception(request)
        data = json.loads(response.decode('utf-8'))
        instances = data.get('Instances', {}).get('Instance', [])
        if not instances:
            return 'Unknown'
        return instances[0].get('Status', 'Unknown')
    except Exception as e:
        logging.error(f'查询实例状态失败: {str(e)}')
        return 'Unknown'


def start_vps_safety():
    if not INSTANCE_ID or '你的' in INSTANCE_ID:
        return False, '❌ INSTANCE_ID 未配置'
    try:
        status = get_vps_status()
        status_l = status.lower()
        if status_l == 'running':
            return True, '✅ 实例已经是 Running，无需开机'
        if status_l in ['starting', 'stopping']:
            return True, f'⏳ 实例当前是 {status}，正在变化中，等待恢复 Running'

        logging.warning('>>> 准备调用 StartInstance()')
        request = StartInstanceRequest.StartInstanceRequest()
        request.set_InstanceId(INSTANCE_ID)
        clt_ecs.do_action_with_exception(request)
        logging.warning('>>> StartInstance() 调用成功')
        return True, '✅ StartInstance() 调用成功，实例正在启动'
    except Exception as e:
        logging.error(f'开机失败: {str(e)}')
        return False, f'❌ 开机失败：{str(e)}'


def stop_vps_safety():
    if not INSTANCE_ID or '你的' in INSTANCE_ID:
        return False, '❌ INSTANCE_ID 未配置'
    try:
        status = get_vps_status()
        status_l = status.lower()
        if status_l == 'stopped':
            return True, '✅ 实例已经是 Stopped，无需关机'
        if status_l == 'stopping':
            return True, f'⏳ 实例当前是 {status}，正在关机中'

        logging.warning('>>> 已触发流量熔断，准备调用 StopInstance()')
        request = StopInstanceRequest.StopInstanceRequest()
        request.set_InstanceId(INSTANCE_ID)
        request.set_ForceStop(True)
        clt_ecs.do_action_with_exception(request)
        logging.warning('>>> StopInstance() 调用成功')
        return True, '✅ StopInstance() 调用成功，实例正在关机'
    except Exception as e:
        logging.error(f'关机失败: {str(e)}')
        return False, f'❌ 关机失败：{str(e)}'

# =========================
# CDT 流量与账单
# =========================
def get_cdt_traffic():
    request = CommonRequest()
    request.set_domain('cdt.aliyuncs.com')
    request.set_version('2021-08-13')
    request.set_action_name('ListCdtInternetTraffic')
    request.set_method('POST')
    try:
        response = clt_ecs.do_action_with_exception(request)
        response_json = json.loads(response.decode('utf-8'))
        total_bytes = sum(
            d.get('Traffic', 0)
            for d in response_json.get('TrafficDetails', [])
        )
        total_gb = total_bytes / (1024 ** 3)
        return round(total_gb, 2)
    except Exception as e:
        logging.error(f'CDT流量查询失败: {str(e)}')
        return 0.0


def get_aliyun_data():
    try:
        balance = '0.00'
        request_bal = QueryAccountBalanceRequest.QueryAccountBalanceRequest()
        request_bal.set_accept_format('json')
        res_bal = clt_bill.do_action_with_exception(request_bal)
        data_bal = json.loads(res_bal.decode('utf-8'))
        if data_bal.get('Success'):
            balance = data_bal.get('Data', {}).get('AvailableAmount', '0.00')

        request_bill = QueryBillOverviewRequest.QueryBillOverviewRequest()
        request_bill.set_accept_format('json')
        request_bill.set_BillingCycle(get_billing_cycle())
        res_bill = clt_bill.do_action_with_exception(request_bill)
        data_bill = json.loads(res_bill.decode('utf-8'))
        cost = 0.0
        if data_bill.get('Success') and data_bill.get('Data'):
            items = data_bill.get('Data', {}).get('Items', {}).get('Item', [])
            cost = sum(float(item.get('PretaxAmount', 0)) for item in items)

        if IS_INTERNATIONAL:
            return (
                '💳 扣费方式：国际站后付费\n'
                f'💵 本月消费（1号至今）：${cost:.2f}'
            )
        return (
            f'💰 账户现金余额：{balance} 元\n'
            f'💵 本月消费（1号至今）：{cost:.2f} 元'
        )
    except Exception as e:
        logging.error(f'查询余额/账单失败: {str(e)}')
        return '💰 账户现金余额：暂无数据\n💵 本月消费（1号至今）：0.00'

