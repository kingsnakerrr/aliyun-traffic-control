# 频道 ID：日报、保活恢复成功、流量熔断关机通知都发这里
TELEGRAM_CHAT_ID = '__TELEGRAM_CHAT_ID__'

# 你的 TG 私聊 ID：机器人只接受这个用户私聊命令
ADMIN_USER_ID = '__ADMIN_USER_ID__'

INSTANCE_ID = '__INSTANCE_ID__'
