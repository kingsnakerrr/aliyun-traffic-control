        "----------------------------------\n"
        f"🕒 时间：{now_text()}\n"
        f"📈 当前流量：{traffic} GB / {MAX_TRAFFIC_GB} GB\n"
        f"🔄 实例状态：{instance_status}\n"
        f"{financial_info}\n"
        f"⚡ 保活运行状态：{keep_status}\n"
        "💡 流量控制脚本运行正常\n"
        "----------------------------------"
    )


