# 国际版设 True，国内版设 False
IS_INTERNATIONAL = __IS_INTERNATIONAL__

# 流量阈值 GB
MAX_TRAFFIC_GB = float(__MAX_TRAFFIC_GB__)

# 状态报告里的账号显示名称
ACCOUNT_NAME = '__ACCOUNT_NAME__'

# 每日报告推送时间，固定按北京时间 UTC+8 判断，不依赖机器时区
DAILY_REPORT_TIME = '__DAILY_REPORT_TIME__'

# 月初自动恢复检测时间：每月 1 号 00:05:00 UTC+8 之后才允许恢复因流量熔断关机的实例
MONTHLY_RESET_OPEN_HOUR = 0
MONTHLY_RESET_OPEN_MINUTE = 5

# 保活开关文件
KEEPALIVE_FLAG_FILE = '/root/aliyun-traffic-control/keepalive_enabled.flag'

# 通知状态文件：避免同一种状态每分钟刷屏
LAST_NOTIFY_FILE = '/root/aliyun-traffic-control/last_notify_state.json'

