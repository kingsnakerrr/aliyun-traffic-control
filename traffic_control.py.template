# =========================
# 定时任务辅助
# =========================
def maybe_send_daily_report():
    if is_daily_report_time():
        if notify_once(daily_report_key(), build_status_text()):
            logging.info(f'已发送每日 {DAILY_REPORT_TIME} 北京时间报告到频道。')
    else:
        # 清理昨天及更早日报 key，避免状态文件越来越大
        state = load_notify_state()
        today_key = daily_report_key()
        old_keys = [k for k in state if k.startswith('daily_report_') and k != today_key]
        if old_keys:
            for key in old_keys:
                del state[key]
            save_notify_state(state)


def should_block_keepalive_by_traffic_stop():
    """因流量熔断关机后，只有每月1号00:05以后且流量低于阈值才恢复。"""
    return has_notify_key('traffic_stop')

# =========================
# cron 保活入口
# =========================
def check_cron_job():
    maybe_send_daily_report()

    traffic = get_cdt_traffic()
    status_before = get_vps_status()
    status_l = status_before.lower()
    logging.info(
        f'cron检查：流量 {traffic} GB / {MAX_TRAFFIC_GB:g} GB，实例状态 {status_before}'
    )

    # 非1号时，清理“月初自动开机通知”状态，方便下个月再次通知
    if now_cn().day != 1:
        clear_notify_key('monthly_reset_start')

    # 超流量：强制关机，并只通知一次。不要在这里 clear traffic_stop，否则会每分钟重复通知。
    if traffic >= MAX_TRAFFIC_GB:
        ok, result = stop_vps_safety()
        logging.warning(result)
        notify_once(
            'traffic_stop',
            build_traffic_stop_notice(traffic, result)
        )
        return

    # 保活暂停：不自动开机，但仍保留超流量关机保护
    if not keepalive_enabled():
        logging.info('保活已暂停，跳过自动开机。')
        clear_notify_key('keepalive_failed')
        return

    # 如果是因为流量熔断关机，必须等每月1号00:05以后且流量低于阈值才恢复
    traffic_stopped = should_block_keepalive_by_traffic_stop()
    if traffic_stopped:
        if not is_month_reset_open_window():
            logging.info('实例此前因流量熔断关机，未到每月1号00:05 UTC+8，暂不自动开机。')
            return

        ok, result = start_vps_safety()
        logging.info(result)
        if ok:
            notify_once(
                'monthly_reset_start',
                build_monthly_reset_start_notice(traffic, result)
            )
            clear_notify_key('traffic_stop')
            set_pending_keepalive(status_before)
        else:
            notify_once(
                'keepalive_failed',
                (
                    '〖月初自动开机失败〗\n\n'
                    f'当前 CDT 流量：{traffic} GB / {MAX_TRAFFIC_GB:g} GB\n'
                    f'失败原因：{result}\n\n'
                    '请检查余额、实例状态、阿里云风控或实例是否已释放。\n'
                    f'实例：{INSTANCE_ID}\n'
                    f'时间：{now_text()}'
                )
            )
        return

    # Running：如果之前有保活 pending，说明恢复完成，发恢复成功通知
    if status_l == 'running':
        pending = get_pending_keepalive()
        if pending:
            old_status = pending.get('status', 'Unknown')
            send_tg(
                TELEGRAM_CHAT_ID,
                build_keepalive_success_notice(old_status, traffic)
            )
            clear_pending_keepalive()
            clear_notify_key('keepalive_action')
            clear_notify_key('keepalive_failed')
        logging.info('实例 Running，保活正常。')
        logging.info('cron脚本执行完毕。')
        return

    # Starting / Stopping：过渡状态，不重复调用 StartInstance
    if status_l in ['starting', 'stopping']:
        set_pending_keepalive(status_before)
        logging.info(f'实例状态 {status_before}，等待状态稳定，不调用 StartInstance。')
        logging.info('cron脚本执行完毕。')
        return

    # Stopped / Unknown / 其他非 Running：普通保活启动
    ok, result = start_vps_safety()
    logging.info(result)
    if ok:
        set_pending_keepalive(status_before)
        notify_once(
            'keepalive_action',
            build_keepalive_action_notice(status_before, result, traffic)
        )
    else:
        set_pending_keepalive(status_before)
        notify_once(
            'keepalive_failed',
            (
                '〖保活启动失败〗\n\n'
                f'检测到实例状态：{status_before}\n'
                f'当前 CDT 流量：{traffic} GB / {MAX_TRAFFIC_GB:g} GB\n'
                f'失败原因：{result}\n\n'
                '请检查余额、实例状态、阿里云风控或实例是否已释放。\n'
                f'实例：{INSTANCE_ID}\n'
                f'时间：{now_text()}'
            )
        )
    logging.info('cron脚本执行完毕。')

