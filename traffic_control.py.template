def build_keepalive_success_notice(old_status, traffic):
    return (
        "🟢【保活恢复成功】\n\n"
        f"之前状态：{old_status}\n"
        "当前状态：Running\n\n"
        f"当前 CDT 流量：{traffic} GB / {MAX_TRAFFIC_GB} GB\n"
        f"🖥 实例：{INSTANCE_ID}\n"
        f"🕒 时间：{now_text()}"
    )


def build_keepalive_action_notice(old_status, result_msg, traffic):
    return (
        "🟡【保活已触发】\n\n"
        f"检测到实例状态：{old_status}\n"
        f"当前 CDT 流量：{traffic} GB / {MAX_TRAFFIC_GB} GB\n"
        f"动作结果：{result_msg}\n\n"
        "系统已开始救活，等待实例恢复 Running 后会再次通知。\n"
        f"🖥 实例：{INSTANCE_ID}\n"
        f"🕒 时间：{now_text()}"
    )


def build_traffic_stop_notice(traffic, result_msg):
    return (
        "🔴【流量熔断关机通知】\n\n"
        f"当前 CDT 流量：{traffic} GB / {MAX_TRAFFIC_GB} GB\n"
        f"动作结果：{result_msg}\n\n"
        "系统已执行关机保护，避免继续产生流量费用。\n"
        f"🖥 实例：{INSTANCE_ID}\n"
        f"🕒 时间：{now_text()}"
    )


# =========================
# cron 保活入口
# =========================

def check_cron_job():
    traffic = get_cdt_traffic()
    status_before = get_vps_status()
    status_l = status_before.lower()

    logging.info(
        f"cron检查：流量 {traffic} GB / {MAX_TRAFFIC_GB} GB，实例状态 {status_before}"
    )

    # 超流量：强制关机，并通知频道
    if traffic >= MAX_TRAFFIC_GB:
        ok, result = stop_vps_safety()
        logging.warning(result)

        notify_once(
            "traffic_stop",
            build_traffic_stop_notice(traffic, result)
        )

        return

    clear_notify_key("traffic_stop")

    # 保活暂停：不自动开机，但仍保留超流量关机保护
    if not keepalive_enabled():
        logging.info("保活已暂停，跳过自动开机。")
        clear_notify_key("keepalive_failed")
        return

    # Running：如果之前有保活 pending，说明恢复完成，发恢复成功通知
    if status_l == "running":
        pending = get_pending_keepalive()
        if pending:
            old_status = pending.get("status", "Unknown")
            send_tg(
                TELEGRAM_CHAT_ID,
                build_keepalive_success_notice(old_status, traffic)
            )
            clear_pending_keepalive()
            clear_notify_key("keepalive_action")
            clear_notify_key("keepalive_failed")

        logging.info("实例 Running，保活正常。")
        logging.info("cron脚本执行完毕。")
        return

    # Starting / Stopping：过渡状态，不重复调用 StartInstance
    if status_l in ["starting", "stopping"]:
        set_pending_keepalive(status_before)
        logging.info(f"实例状态 {status_before}，等待状态稳定，不调用 StartInstance。")
        logging.info("cron脚本执行完毕。")
        return

    # Stopped / Unknown / 其他非 Running：触发保活启动
    ok, result = start_vps_safety()
    logging.info(result)

    if ok:
        set_pending_keepalive(status_before)
        notify_once(
            "keepalive_action",
            build_keepalive_action_notice(status_before, result, traffic)
        )
    else:
        set_pending_keepalive(status_before)
        notify_once(
            "keepalive_failed",
            (
                "🟠【保活启动失败】\n\n"
                f"检测到实例状态：{status_before}\n"
                f"当前 CDT 流量：{traffic} GB / {MAX_TRAFFIC_GB} GB\n"
                f"失败原因：{result}\n\n"
                "请检查余额、实例状态、阿里云风控或实例是否已释放。\n"
                f"🖥 实例：{INSTANCE_ID}\n"
                f"🕒 时间：{now_text()}"
            )
        )

    logging.info("cron脚本执行完毕。")


# =========================
# Bot 命令
# =========================

@run_async
def help_command(update: Update, context: CallbackContext):
    if not is_admin(update):
        return
    context.bot.send_message(chat_id=get_chat_id(update), text=build_help_text())


@run_async
def status_command(update: Update, context: CallbackContext):
    if not is_admin(update):
        return

    logging.info(
        f"收到 /status，chat_id={get_chat_id(update)}, "
        f"user_id={update.effective_user.id if update.effective_user else None}"
    )

    context.bot.send_message(chat_id=get_chat_id(update), text=build_status_text())


@run_async
def traffic_command(update: Update, context: CallbackContext):
    if not is_admin(update):
        return

    traffic = get_cdt_traffic()
    text = f"📈 当前 CDT 流量：{traffic} GB / {MAX_TRAFFIC_GB} GB"
    context.bot.send_message(chat_id=get_chat_id(update), text=text)


@run_async
def bill_command(update: Update, context: CallbackContext):
    if not is_admin(update):
        return

    context.bot.send_message(chat_id=get_chat_id(update), text=get_aliyun_data())


@run_async
def startvps_command(update: Update, context: CallbackContext):
    if not is_admin(update):
        return

    ok, result = start_vps_safety()
    context.bot.send_message(chat_id=get_chat_id(update), text=result)


@run_async
def stopvps_command(update: Update, context: CallbackContext):
    if not is_admin(update):
        return

    ok, result = stop_vps_safety()
    context.bot.send_message(chat_id=get_chat_id(update), text=result)


@run_async
def keepon_command(update: Update, context: CallbackContext):
    if not is_admin(update):
        return

    set_keepalive_enabled(True)
    clear_notify_key("keepalive_action")
    clear_notify_key("keepalive_failed")
    clear_pending_keepalive()

    context.bot.send_message(
        chat_id=get_chat_id(update),
        text="✅ 自动保活已开启。cron 检查时，流量未超限会自动开机。"
    )


@run_async
def keepoff_command(update: Update, context: CallbackContext):
    if not is_admin(update):
        return

    set_keepalive_enabled(False)
    clear_notify_key("keepalive_action")
    clear_notify_key("keepalive_failed")
    clear_pending_keepalive()

    context.bot.send_message(
        chat_id=get_chat_id(update),
        text="⏸ 自动保活已暂停。cron 检查时不会自动开机，但超流量仍会关机。"
    )


@run_async
def report_command(update: Update, context: CallbackContext):
    if not is_admin(update):
        return

    send_tg(TELEGRAM_CHAT_ID, build_status_text())

    context.bot.send_message(
        chat_id=get_chat_id(update),
        text="✅ 已发送完整报告到频道。"
    )


def send_daily_report(context: CallbackContext):
    try:
        send_tg(TELEGRAM_CHAT_ID, build_status_text())
        logging.info("已发送每日9点报告到频道。")
    except Exception as e:
        logging.error(f"每日9点报告发送失败: {str(e)}")


# =========================
# 主入口
# =========================

def main():
    if len(sys.argv) > 1 and sys.argv[1] == '--cron':
        check_cron_job()
        return

    if TELEGRAM_BOT_TOKEN == '你的TG机器人TOKEN':
        logging.error("请先配置 TELEGRAM_BOT_TOKEN")
        return

    if not os.path.exists(KEEPALIVE_FLAG_FILE):
        set_keepalive_enabled(True)

    updater = Updater(
        TELEGRAM_BOT_TOKEN,
        workers=4,
        request_kwargs={
            'read_timeout': 10,
            'connect_timeout': 10
        }
    )

    dispatcher = updater.dispatcher

    dispatcher.add_handler(CommandHandler("help", help_command))
    dispatcher.add_handler(CommandHandler("status", status_command))
    dispatcher.add_handler(CommandHandler("traffic", traffic_command))
    dispatcher.add_handler(CommandHandler("bill", bill_command))
    dispatcher.add_handler(CommandHandler("startvps", startvps_command))
    dispatcher.add_handler(CommandHandler("stopvps", stopvps_command))
    dispatcher.add_handler(CommandHandler("keepon", keepon_command))
    dispatcher.add_handler(CommandHandler("keepoff", keepoff_command))
    dispatcher.add_handler(CommandHandler("report", report_command))

    updater.job_queue.run_daily(
        send_daily_report,
        time=datetime.time(hour=9, minute=0, second=0)
    )

    updater.start_polling(clean=True)

    logging.info(
        "Telegram Bot 已启动：私聊控制，9点报告/保活/关机通知发送频道。"
    )

    updater.idle()


if __name__ == '__main__':
    main()
