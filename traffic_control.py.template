    context.bot.send_message(chat_id=get_chat_id(update), text=get_aliyun_data())


@run_async
def startvps_command(update: Update, context: CallbackContext):
    if not is_admin(update):
        return
    ok, result = start_vps_safety()
    if ok:
        clear_notify_key('traffic_stop')
    context.bot.send_message(chat_id=get_chat_id(update), text=result)


@run_async
def stopvps_command(update: Update, context: CallbackContext):
    if not is_admin(update):
        return
    ok, result = stop_vps_safety()
    context.bot.send_message(chat_id=get_chat_id(update), text=result)


@run_async
def keepon_command(update: Update, context: CallbackContext):
    if not is_admin(update):
        return
    set_keepalive_enabled(True)
    clear_notify_key('keepalive_action')
    clear_notify_key('keepalive_failed')
    clear_pending_keepalive()
    context.bot.send_message(
        chat_id=get_chat_id(update),
        text='✅ 自动保活已开启。cron 检查时，流量未超限会自动开机。'
    )


@run_async
def keepoff_command(update: Update, context: CallbackContext):
    if not is_admin(update):
        return
    set_keepalive_enabled(False)
    clear_notify_key('keepalive_action')
    clear_notify_key('keepalive_failed')
    clear_pending_keepalive()
    context.bot.send_message(
        chat_id=get_chat_id(update),
        text='⏸ 自动保活已暂停。cron 检查时不会自动开机，但超流量仍会关机。'
    )


@run_async
def report_command(update: Update, context: CallbackContext):
    if not is_admin(update):
        return
    send_tg(TELEGRAM_CHAT_ID, build_status_text())
    context.bot.send_message(
        chat_id=get_chat_id(update),
        text='✅ 已发送完整报告到频道。'
    )


def send_daily_report(context=None):
    try:
        send_tg(TELEGRAM_CHAT_ID, build_status_text())
        logging.info('已手动发送日报到频道。')
    except Exception as e:
        logging.error(f'日报发送失败: {str(e)}')

# =========================
# 主入口
# =========================
def main():
    if len(sys.argv) > 1 and sys.argv[1] == '--cron':
        check_cron_job()
        return

    if len(sys.argv) > 1 and sys.argv[1] == '--report':
        send_tg(TELEGRAM_CHAT_ID, build_status_text())
        return

    if TELEGRAM_BOT_TOKEN == '你的TG机器人TOKEN':
        logging.error('请先配置 TELEGRAM_BOT_TOKEN')
        return

    if not os.path.exists(KEEPALIVE_FLAG_FILE):
        set_keepalive_enabled(True)

    updater = Updater(
        TELEGRAM_BOT_TOKEN,
        workers=4,
        request_kwargs={
            'read_timeout': 10,
            'connect_timeout': 10
        }
    )

    dispatcher = updater.dispatcher
    dispatcher.add_handler(CommandHandler('help', help_command))
    dispatcher.add_handler(CommandHandler('status', status_command))
    dispatcher.add_handler(CommandHandler('traffic', traffic_command))
    dispatcher.add_handler(CommandHandler('bill', bill_command))
    dispatcher.add_handler(CommandHandler('startvps', startvps_command))
    dispatcher.add_handler(CommandHandler('stopvps', stopvps_command))
    dispatcher.add_handler(CommandHandler('keepon', keepon_command))
    dispatcher.add_handler(CommandHandler('keepoff', keepoff_command))
    dispatcher.add_handler(CommandHandler('report', report_command))

    updater.start_polling(clean=True)
    logging.info('Telegram Bot 已启动：私聊控制，日报由 cron 按北京时间判断发送，保活/关机通知发送频道。')
    updater.idle()


if __name__ == '__main__':
    main()
